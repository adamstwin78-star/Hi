local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer

local Character = LocalPlayer.Character or LocalPlayer.CharacterAdded:Wait()
local Humanoid = Character:WaitForChild("Humanoid")

LocalPlayer.CharacterAdded:Connect(function(c)
    Character = c
    Humanoid = c:WaitForChild("Humanoid")
end)

local Roles = { Murderer = nil, Sheriff = nil, Hero = nil }
local ESPInstances = {}
local BillboardInstances = {}
local ESPToggle = true
local SilentAIMEnabled = true

local RC = RaycastParams.new()
RC.IgnoreWater = true
RC.FilterType = Enum.RaycastFilterType.Blacklist

local AttackAnimations = {
    "rbxassetid://2467567750", "rbxassetid://1957618848",
    "rbxassetid://2470501967", "rbxassetid://2467577524"
}

local RoleColors = {
    Murderer = Color3.fromRGB(255, 0,   0),
    Sheriff  = Color3.fromRGB(0,   120, 255),
    Hero     = Color3.fromRGB(255, 140, 0),
    Innocent = Color3.fromRGB(0,   255, 0),
}

local RoleLabels = {
    Murderer = "Murd",
    Sheriff  = "Sheriff",
    Hero     = "Hero",
    Innocent = "Inno",
}

local ESPFolder = Instance.new("Folder")
ESPFolder.Name = "MM2_ESP"
ESPFolder.Parent = game:GetService("CoreGui")

local BBFolder = Instance.new("Folder")
